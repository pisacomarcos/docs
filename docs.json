            ]
          },
          {
            "group": "Admin Panel",
            "pages": [
              "admin/overview",
              "admin/schedules",
              "admin/attendance",
              "admin/employees",
              "admin/payroll",
              "admin/communication"
            ]
          },
          {
            "group": "Employee Portal",
            "pages": [
              "employee/overview",
              "employee/clock-in",
              "employee/schedules",
              "employee/requests"
            ]
          },
          {
            "group": "Campus",
            "pages": [
              "campus/overview",
              "campus/courses",
              "campus/wiki",
              "campus/certificates"
            ]
          },
          {
            "group": "Recruitment",
            "pages": [
              "careers/overview",
              "careers/job-listings",
              "careers/applications",
              "careers/pipeline"
            ]
          }
        ]
      },
      {
